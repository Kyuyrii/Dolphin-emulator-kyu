#!/bin/bash

unset QT_QPA_PLATFORM

export XDG_CONFIG_HOME="$SNAP_USER_COMMON/.config"
export XDG_DATA_HOME="$SNAP_USER_COMMON/.local/share"
export XDG_CACHE_HOME="$SNAP_USER_COMMON/.cache"

mkdir -p "$XDG_CONFIG_HOME"
mkdir -p "$XDG_DATA_HOME"
mkdir -p "$XDG_CACHE_HOME"

if [ -d "$SNAP_USER_DATA/.config/dolphin-emu" ]; then
    cp -r "$SNAP_USER_DATA/.config/dolphin-emu" "$SNAP_USER_COMMON/.config/"
    rm -rf "$SNAP_USER_DATA/.config/dolphin-emu"
fi

if [ -d "$SNAP_USER_DATA/.local/share/dolphin-emu" ]; then
    cp -r "$SNAP_USER_DATA/.local/share/dolphin-emu" "$SNAP_USER_COMMON/.local/share/"
    rm -rf "$SNAP_USER_DATA/.local/share/dolphin-emu"
fi

exec "$@"
